# Version control — exclude .git contents but keep HEAD, packed-refs,
# loose refs, and the object database.  Uses .git/* (not .git/) so the
# directory entry itself stays in the build context and the walker descends
# into it, allowing the negation patterns to re-include specific files.
# .git/ would exclude the directory entry, causing SkipDir before
# negations are evaluated (moby#31630).
#
# Kept for commit-hash resolution (production stage):
#   HEAD, packed-refs, refs/heads/*
# Kept for changelog generation (gitlog stage):
#   objects/ (commit graph needed by `git log`)
.git/*
!.git/HEAD
!.git/packed-refs
!.git/refs
!.git/refs/heads
!.git/refs/heads/*
!.git/objects
.gitignore

# Python caches
**/__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.hypothesis/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Data — mounted as a Docker volume at runtime; not baked into the image
data/

# Logs — mounted as a Docker volume at runtime
logs/

# Runtime artifacts
server.pid
*.log

# macOS
.DS_Store

# Editor / IDE
.cursor/
.vscode/
.idea/
*.swp
*.swo

# CI
.github/

# Docs (not needed in image)
docs/
*.md

# Version control — exclude .git contents but keep HEAD, packed-refs, and
# loose refs for commit resolution.  Uses .git/* (not .git/) so the
# directory entry itself stays in the build context and the walker descends
# into it, allowing the negation patterns to re-include specific files.
# .git/ would exclude the directory entry, causing SkipDir before
# negations are evaluated (moby#31630).
#
# Loose refs (e.g. .git/refs/heads/main) are needed because modern Git
# only writes packed-refs on `git gc` / `git pack-refs`; most checkouts
# store the current branch hash as a loose file under refs/heads/.
.git/*
!.git/HEAD
!.git/packed-refs
!.git/refs
!.git/refs/heads
!.git/refs/heads/*
.gitignore

# Python caches
**/__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.hypothesis/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Data — mounted as a Docker volume at runtime; not baked into the image
data/

# Logs — mounted as a Docker volume at runtime
logs/

# Runtime artifacts
server.pid
*.log

# macOS
.DS_Store

# Editor / IDE
.cursor/
.vscode/
.idea/
*.swp
*.swo

# CI
.github/

# Docs (not needed in image)
docs/
*.md
